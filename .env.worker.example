# MQTT worker identity / routing
MQTT_WORKER_NAME=ai_timesheet
MQTT_OPERATOR=ai_timesheet
MQTT_INBOUND_TOPIC=ai_timesheet
MQTT_REPLY_TOPIC=ai_timesheet_reply
MQTT_REPLY_TO=line_webhook
ATTENDANCE_REPLY_VIA_MQTT=1

# MQTT broker
MQTT_HOST=your_mqtt_broker_host
MQTT_USERNAME=your_mqtt_username
MQTT_PASSWORD=your_mqtt_password

# LLM / OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=openai/gpt-4o-mini

# Optional direct LINE fallback (used when MQTT publish reply fails)
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_optional
LINE_URL=https://api.line.me/v2/bot/message/reply
